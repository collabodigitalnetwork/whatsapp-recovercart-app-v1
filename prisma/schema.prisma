// Prisma schema for WhatsApp RecoverCart

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ------------------
// Enums
// ------------------

enum ShopPlan {
  FREE
  BASIC
  GROWTH
  ENTERPRISE
}

enum ShopUserRole {
  OWNER
  MANAGER
  OPS
  ANALYST
}

enum CartStatus {
  OPEN
  RECOVERED
  EXPIRED
}

enum WorkflowStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum RecoveryChannel {
  WHATSAPP
  EMAIL
}

enum StepStatus {
  SCHEDULED
  SENT
  FAILED
  SKIPPED
}

enum TemplateCategory {
  MARKETING
  UTILITY
  AUTHENTICATION
}

enum WhatsAppStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  REPLIED
  FAILED
}

enum MessageContext {
  CART
  DELIVERY
  SUPPORT
  RETENTION
}

enum OrderStatus {
  OPEN
  PAID
  PARTIALLY_FULFILLED
  FULFILLED
  CANCELLED
}

enum DeliveryStatus {
  CREATED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  DELAYED
  FAILED_ATTEMPT
  EXCEPTION
}

enum ExperimentType {
  TEMPLATE
  TIMING
  INCENTIVE
  WORKFLOW
}

enum ExperimentStatus {
  DRAFT
  RUNNING
  COMPLETED
  PAUSED
  CANCELLED
}

// ------------------
// Core Models
// ------------------

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Shop {
  id                String              @id
  myshopifyDomain   String              @unique
  accessToken       String
  plan              ShopPlan            @default(BASIC)
  installedAt       DateTime            @default(now())
  lastSeenAt        DateTime            @default(now())
  settings          ShopSettings?
  users             ShopUser[]
  templates         Template[]
  segments          Segment[]
  carts             Cart[]
  orders            Order[]
  whatsappMessages  WhatsAppMessage[]
  analytics         AnalyticsSnapshot[]
  recoveryWorkflows RecoveryWorkflow[]
  eventLogs         EventLog[]
  experiments       Experiment[]
}

model ShopSettings {
  id                    String   @id @default(cuid())
  shopId                String   @unique
  whatsappEnabled       Boolean  @default(false)
  whatsappPhoneNumberId String?
  businessAccountId     String?
  messageLimitPerDay    Int      @default(3)
  timezone              String   @default("UTC")
  defaultLanguage       String   @default("en")
  features              Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  shop                  Shop     @relation(fields: [shopId], references: [id])
}

model ShopUser {
  id        String       @id @default(cuid())
  shopId    String
  email     String
  role      ShopUserRole @default(MANAGER)
  lastLogin DateTime?
  createdAt DateTime     @default(now())
  shop      Shop         @relation(fields: [shopId], references: [id])

  @@unique([shopId, email])
}

model Segment {
  id           String   @id @default(cuid())
  shopId       String
  name         String
  definition   Json
  audienceSize Int?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  shop         Shop     @relation(fields: [shopId], references: [id])
}

model Cart {
  id            String            @id
  shopId        String
  checkoutId    String            @unique
  customerId    String?
  customerEmail String?
  customerPhone String?
  currency      String
  subtotal      Decimal           @default(0)
  abandonedAt   DateTime
  recoveredAt   DateTime?
  status        CartStatus        @default(OPEN)
  metadata      Json?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  items         CartItem[]
  workflow      RecoveryWorkflow?
  shop          Shop              @relation(fields: [shopId], references: [id])
  order         Order?            @relation("CartOrder")

  @@index([shopId, status])
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  productId String
  title     String
  quantity  Int     @default(1)
  price     Decimal @default(0)
  cart      Cart    @relation(fields: [cartId], references: [id])
}

model RecoveryWorkflow {
  id              String         @id @default(cuid())
  cartId          String         @unique
  shopId          String
  templateVersion String
  rules           Json
  status          WorkflowStatus @default(PENDING)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  steps           RecoveryStep[]
  shop            Shop           @relation(fields: [shopId], references: [id])
  cart            Cart           @relation(fields: [cartId], references: [id])
}

model RecoveryStep {
  id          String           @id @default(cuid())
  workflowId  String
  sequence    Int
  scheduledAt DateTime
  executedAt  DateTime?
  channel     RecoveryChannel  @default(WHATSAPP)
  incentive   Json?
  status      StepStatus       @default(SCHEDULED)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  messageLogs MessageLog[]
  workflow    RecoveryWorkflow @relation(fields: [workflowId], references: [id])

  @@unique([workflowId, sequence])
}

model Template {
  id         String           @id @default(cuid())
  shopId     String
  name       String
  category   TemplateCategory
  body       String
  language   String           @default("en")
  variables  Json?
  approved   Boolean          @default(false)
  latestMeta Json?
  createdBy  String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  shop       Shop             @relation(fields: [shopId], references: [id])

  @@unique([shopId, name, language])
}

model MessageLog {
  id                String           @id @default(cuid())
  recoveryStepId    String?
  whatsappMessageId String?
  metadata          Json?
  responsePayload   Json?
  createdAt         DateTime         @default(now())
  recoveryStep      RecoveryStep?    @relation(fields: [recoveryStepId], references: [id])
  whatsappMessage   WhatsAppMessage? @relation(fields: [whatsappMessageId], references: [id])
}

model WhatsAppMessage {
  id            String         @id @default(cuid())
  shopId        String
  wabaMessageId String         @unique
  toPhoneNumber String
  templateName  String?
  body          String
  variables     Json?
  status        WhatsAppStatus @default(QUEUED)
  failureReason String?
  context       MessageContext
  sentAt        DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  shop          Shop           @relation(fields: [shopId], references: [id])
  messageLogs   MessageLog[]
}

model Order {
  id                String      @id
  shopId            String
  shopifyOrderId    String      @unique
  cartId            String?     @unique
  customerId        String?
  totalPrice        Decimal     @default(0)
  currency          String
  status            OrderStatus @default(OPEN)
  placedAt          DateTime
  fulfillmentStatus String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  deliveries        Delivery[]
  shop              Shop        @relation(fields: [shopId], references: [id])
  cart              Cart?       @relation("CartOrder", fields: [cartId], references: [id])
}

model Delivery {
  id             String          @id @default(cuid())
  orderId        String
  carrier        String
  trackingNumber String
  trackingUrl    String?
  estimatedAt    DateTime?
  latestStatus   DeliveryStatus  @default(CREATED)
  lastStatusAt   DateTime?
  metadata       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  events         DeliveryEvent[]
  order          Order           @relation(fields: [orderId], references: [id])

  @@unique([carrier, trackingNumber])
}

model DeliveryEvent {
  id         String         @id @default(cuid())
  deliveryId String
  status     DeliveryStatus
  rawPayload Json
  occurredAt DateTime
  createdAt  DateTime       @default(now())
  delivery   Delivery       @relation(fields: [deliveryId], references: [id])
}

model AnalyticsSnapshot {
  id        String   @id @default(cuid())
  shopId    String
  date      DateTime
  metric    String
  value     Float
  dimension Json?
  createdAt DateTime @default(now())
  shop      Shop     @relation(fields: [shopId], references: [id])

  @@index([shopId, metric, date])
}

model Experiment {
  id           String           @id @default(cuid())
  shopId       String
  name         String
  type         ExperimentType
  status       ExperimentStatus @default(DRAFT)
  hypothesis   String?
  variants     Json // Array of variant configurations
  trafficSplit Int              @default(50)
  startDate    DateTime?
  endDate      DateTime?
  duration     Int              @default(7) // days
  winner       String?
  significance Float?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  shop         Shop             @relation(fields: [shopId], references: [id])
  results      ExperimentResult[]

  @@index([shopId, status])
}

model ExperimentResult {
  id           String     @id @default(cuid())
  experimentId String
  variantName  String
  visits       Int        @default(0)
  conversions  Int        @default(0)
  revenue      Decimal    @default(0)
  date         DateTime
  createdAt    DateTime   @default(now())
  experiment   Experiment @relation(fields: [experimentId], references: [id])

  @@unique([experimentId, variantName, date])
}

model EventLog {
  id              String   @id @default(cuid())
  shopId          String
  eventType       String
  occurredAt      DateTime @default(now())
  customerHash    String?
  payload         Json
  ingestionSource String
  createdAt       DateTime @default(now())
  shop            Shop     @relation(fields: [shopId], references: [id])

  @@index([shopId, eventType, occurredAt])
}
